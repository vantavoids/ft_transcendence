load('../../tiltlib.star', 'detect_engine', 'run_flags', 'container_serve')

DOCKER = detect_engine()
FLAGS  = run_flags(DOCKER)

local_resource(
    'notification-db',
    serve_cmd=container_serve(DOCKER, FLAGS, 'notification-db',
        '--network ft_transcendence ' +
        '--env-file .env ' +
        '-v notification_db_data:/var/lib/postgresql/data ' +
        'docker.io/postgres:17-alpine'
    ),
    resource_deps=['dev-network'],
    labels=['notification'],
)

local_resource(
    'notification',
    cmd=DOCKER + ' build -t notification-service -f Dockerfile.dev .',
    serve_cmd=(
        "trap '" + DOCKER + ' rm -f notification notification-migrate 2>/dev/null || true' + "' TERM INT EXIT; " +
        DOCKER + ' rm -f notification notification-migrate 2>/dev/null || true; ' +
        DOCKER + ' run ' + FLAGS + '--rm --name notification-migrate ' +
        '--network ft_transcendence ' +
        '--env-file .env ' +
        'notification-service npx prisma migrate deploy && ' +
        DOCKER + ' run ' + FLAGS + '--name notification --rm ' +
        '--network ft_transcendence ' +
        '--env-file .env ' +
        '-e NODE_ENV=development ' +
        '-v $(pwd)/src:/app/src ' +
        'notification-service'
    ),
    deps=['Dockerfile.dev', 'package.json', 'prisma'],
    resource_deps=['notification-db', 'rabbitmq'],
    labels=['notification'],
)
