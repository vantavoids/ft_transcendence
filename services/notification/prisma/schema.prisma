generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
	MENTION
	DM
	FRIEND_REQUEST
	GUILD_INVITE
}

model NotificationEntity {
  id					String		@id	@default(uuid())
  userId			String
	type				NotificationType
	payload			Json
	read				Boolean		@default(false)
	created_at	DateTime	@default(now())

	@@index([userId, read])
}
